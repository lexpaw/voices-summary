{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voices Summary",
  "version": "0.1.0",
  "identifier": "com.openai.voices-summary",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voices Summary",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "targets": "all"
  }
}
